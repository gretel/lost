-- allium: 3
-- test-harness.allium
--
-- Scope: Hardware A/B test harness — test modes, config matrices,
--        pass/fail criteria, experiment lifecycle
-- Includes: decode/scan/tx/bridge test modes, ConfigPoint matrix,
--           result collection, flush timing, frequency tolerance
-- Excludes:
--   - Python test framework internals (pytest, asyncio)
--   - Heltec firmware details
--   - Serial/USB transport
--   - Dashboard rendering

use "./meshcore-bridge.allium" as meshcore

-- Note: lora-sdr.allium removed — no such file exists.
-- Frame and ScanDetection types inlined below.

-- ==========================================================================
-- Value types
-- ==========================================================================

-- Inlined from lora-sdr.allium (no separate spec file)
value Frame {
    payload: List<Integer>
    crc_ok: Boolean
    snr_db: Float?
    sf: Integer
    bw: Integer
    freq_hz: Float
    cr: Integer
    sync_word: Integer
}

value ScanDetection {
    freq_hz: Float
    ratio: Float
    sf: Integer?
    chirp_slope: Float?
    sync_word: Integer?
}

value ConfigPoint {
    sf: Integer                         -- spreading factor 7-12
    bw: Integer                         -- bandwidth Hz
    freq_mhz: Float                     -- center frequency MHz
    tx_power: Integer                   -- dBm (default 2)
    cr: Integer                         -- coding rate 5-8 (default 8)
}

value DecodeResult {
    config: ConfigPoint
    tx_ok: Boolean
    frames: List<Frame>
    crc_ok: Integer
    crc_fail: Integer
    best_snr: Float?
    detected_sfs: Map<Integer, Integer> -- SF -> count histogram
}

value ScanResult {
    config: ConfigPoint
    tx_ok: Boolean
    detections: List<ScanDetection>
    det_count: Integer
    best_ratio: Float?
    best_chirp_slope: Float?            -- best chirp slope observed
    best_sf: Integer?
    best_sync_word: Integer?            -- sync word of best detection
    sweeps: Integer
    avg_sweep_ms: Integer
    overflows: Integer
}

value BridgePhaseResult {
    phase: String                       -- A, B, C, D, F
    success: Boolean
    detail: String?
}

value TxResult {
    config: ConfigPoint
    tx_ok: Boolean
    advert_received: Boolean
    message_received: Boolean?
}

-- ==========================================================================
-- Configuration
-- ==========================================================================

config {
    settle_time: Duration = 2.seconds       -- PLL lock after radio change
    flush_decode: Duration = 5.seconds      -- base decode pipeline flush
    flush_scan: Duration = 8.seconds        -- scan sweep flush
    freq_tolerance: Integer = 200000        -- +/- 200 kHz acceptance window
    scan_min_ratio: Float = 8.0             -- detection threshold
    decode_tx_per_point: Integer = 3        -- ADVERTs per decode config point
    scan_tx_repeats: Integer = 3            -- TX per config point in scan mode
}

-- ==========================================================================
-- External entities
-- ==========================================================================

external entity HeltecDevice {
    -- Heltec V3 LoRa device used as reference TX/RX
    -- Connected via serial or TCP bridge
}

external entity SdrUnderTest {
    -- The gr4-lora SDR transceiver being tested
    -- Connected via CBOR/UDP
}

-- ==========================================================================
-- Test experiment lifecycle
-- ==========================================================================

entity Experiment {
    mode: decode | scan | tx | bridge
    matrix: List<ConfigPoint>
    status: configuring | running | complete

    -- Provenance
    git_sha: String                         -- embedded binary SHA
    hypothesis: String?                     -- A/B hypothesis text
    label: String?                          -- run label for comparison
    config_path: String?                    -- TOML config file path
    binary_path: String?                    -- SDR binary override (A/B)
    attach: Boolean                         -- attach to running SDR (no lifecycle)

    results_decode: List<DecodeResult>?
    results_scan: List<ScanResult>?
    results_tx: List<TxResult>?
    results_bridge: List<BridgePhaseResult>?

    transitions status {
        configuring -> running
        running -> complete
        terminal: complete
    }
}

entity TestPoint {
    config: ConfigPoint
    experiment: Experiment
    status: pending | settling | collecting | evaluating | done

    transitions status {
        pending -> settling
        settling -> collecting
        collecting -> evaluating
        evaluating -> done
        terminal: done
    }
}

-- ==========================================================================
-- Rules — Common
-- ==========================================================================

rule RadioSettles {
    when: point: TestPoint.status transitions_to settling

    ensures: point.status = collecting
        after config.settle_time

    @guidance
        -- After changing radio parameters (SF, BW, freq), wait
        -- for PLL to lock and pipeline to stabilize.
        -- 2 seconds default. Longer for large frequency changes.
}

rule FlushPipeline {
    when: point: TestPoint.status transitions_to collecting

    @guidance
        -- Flush duration depends on mode:
        --   decode: airtime(sf, bw) + 3s margin
        --   scan: 8s base (multiple sweep cycles needed)
        -- SF12/BW62.5k has ~4.5s airtime, so flush = ~7.5s.
        -- Dynamic: computed from Semtech AN1200.13 airtime formula.
}

rule FrequencyTolerance {
    when: frame received during collection

    requires: |frame.phy.freq - point.config.freq_mhz * 1e6| <= config.freq_tolerance

    @guidance
        -- Accept events within +/- 200 kHz of TX frequency.
        -- Accounts for CFO and frequency estimation granularity.
}

-- ==========================================================================
-- Rules — Decode mode
-- ==========================================================================

rule DecodeTest {
    when: point: TestPoint.status = collecting
    requires: point.experiment.mode = decode

    @guidance
        -- 1. Configure Heltec to TX ADVERT at point.config params
        -- 2. Heltec sends config.decode_tx_per_point ADVERTs (default 3)
        -- 3. SDR receives and decodes
        -- 4. Collect lora_frame events matching frequency
        -- 5. Count CRC OK / CRC fail
        -- Pass: at least one CRC OK frame received
        -- Hamburg deployment: 100% CRC OK expected on-tune
}

-- ==========================================================================
-- Rules — Scan mode
-- ==========================================================================

rule ScanTest {
    when: point: TestPoint.status = collecting
    requires: point.experiment.mode = scan

    @guidance
        -- 1. Configure Heltec to TX ADVERT x3 (repeated TX)
        -- 2. SDR scanner runs sweep cycles
        -- 3. Collect scan_spectrum events
        -- 4. Look for detections at TX frequency
        -- Pass: detection with ratio >= scan_min_ratio
        -- Best chirp slope and SF recorded for analysis
}

-- ==========================================================================
-- Rules — TX mode
-- ==========================================================================

rule TxTest {
    when: point: TestPoint.status = collecting
    requires: point.experiment.mode = tx

    @guidance
        -- 1. Configure SDR to TX ADVERT at point.config params
        -- 2. Heltec listens via meshcore_py
        -- 3. Check for ADVERTISEMENT event on Heltec
        -- 4. Optionally send TXT_MSG, check for CONTACT_MSG_RECV
        -- Pass: Heltec receives the ADVERT
        -- Auto-reconnect on set_radio (Heltec may reboot)
}

-- ==========================================================================
-- Rules — Bridge mode (4-phase round-trip)
-- ==========================================================================

rule BridgeTestPhaseA {
    when: bridge test begins

    @guidance
        -- Phase A: Heltec ADVERT -> Bridge RX
        -- Heltec broadcasts ADVERT. Bridge should receive it,
        -- auto-learn contact, extract pubkey.
        -- Skipped after first successful contact exchange.
        -- Pass: contact learned by bridge
}

rule BridgeTestPhaseB {
    when: Phase A complete or skipped

    @guidance
        -- Phase B: Bridge ADVERT -> Heltec RX
        -- Bridge broadcasts ADVERT via SDR TX.
        -- Heltec should receive it (ADVERTISEMENT event).
        -- Verifies SDR TX path end-to-end.
        -- Pass: Heltec receives bridge ADVERT
}

rule BridgeTestPhaseC {
    when: Phase B complete

    @guidance
        -- Phase C: Bridge TXT_MSG -> Heltec RX
        -- Bridge sends encrypted private message to Heltec.
        -- ECDH key exchange, AES encrypt, MAC.
        -- Heltec should receive CONTACT_MSG_RECV event.
        -- Pass: Heltec receives and decrypts message
}

rule BridgeTestPhaseD {
    when: Phase C complete

    @guidance
        -- Phase D: Heltec TXT_MSG -> Bridge RX
        -- Heltec sends encrypted message to bridge.
        -- Bridge should decrypt and deliver.
        -- Verifies full SDR RX + MeshCore decrypt path.
        -- Pass: bridge receives and decrypts message
}

rule BridgeTestPhaseF {
    when: Phase D complete

    @guidance
        -- Phase F: Bridge GRP_TXT -> Heltec RX
        -- Bridge sends group channel message (PSK encrypted).
        -- Heltec should receive on shared channel.
        -- Verifies group messaging path.
        -- Pass: Heltec receives group message
}

-- ==========================================================================
-- Rules — Attach mode
-- ==========================================================================

rule AttachToRunningSDR {
    when: experiment: Experiment.attach = true

    @guidance
        -- With --attach, harness connects to an already-running
        -- lora_trx or lora_scan. Only serial_bridge is started.
        -- SDR binary lifecycle not managed by harness.
        -- Useful for live demos or manual debugging sessions.
}

-- ==========================================================================
-- Rules — A/B binary comparison
-- ==========================================================================

rule ABBinaryComparison {
    when: experiment: Experiment.binary_path != null

    @guidance
        -- With --binary, harness uses the specified SDR binary
        -- instead of the default ./build/apps/lora_trx.
        -- git_sha in output JSON records which build was used.
        -- Run baseline (default) then variant (--binary) to compare.
}

-- ==========================================================================
-- Predefined test matrices
-- ==========================================================================

-- Matrices are named collections of ConfigPoints.
-- Each matrix exercises a different dimension of the parameter space.

-- Matrices are concrete in lora_test.py MATRICES dict.
-- Point counts and descriptions match the implementation.

deferred TestMatrix.basic               -- 3 pts: SF8/12/7 at BW62.5k, varied freq
deferred TestMatrix.full                -- 8 pts: SF7-12 x BW62.5k/125k/250k, varied freq
deferred TestMatrix.dc_edge             -- 10 pts: varied SF/BW/power at 869.618 MHz
deferred TestMatrix.sf_sweep            -- 6 pts: SF7-12 at BW62.5k, 869.618 MHz
deferred TestMatrix.bw_sweep            -- 3 pts: BW62.5k/125k/250k at SF8
deferred TestMatrix.power_sweep         -- 5 pts: +2/0/-4/-9/-14 dBm at SF8/BW62.5k
deferred TestMatrix.bridge_full         -- 4 pts: SF7-10, mixed BW for <1.5s airtime
deferred TestMatrix.bw125k_sweep        -- 3 pts: SF7-9 at BW125k
deferred TestMatrix.bw250k_sweep        -- 4 pts: SF7-10 at BW250k
deferred TestMatrix.meshcore_presets    -- 4 pts: EU/UK Narrow/Long/Medium + Czech
deferred TestMatrix.lorawan_eu          -- 4 pts: EU868 Join CH1-3 + RX2
deferred TestMatrix.baseline            -- 16 pts: SF7-12 x BW62.5k/125k/250k @10dBm

-- ==========================================================================
-- Invariants
-- ==========================================================================

invariant UniquePayloads {
    for point in TestPoint:
        -- Never repeat identical packets across config points.
        -- Each ADVERT has a unique timestamp, so multiple TX per
        -- point (decode_tx_per_point) are distinguishable.
        -- Different config points use different radio params.

    @guidance
        -- Payload uniqueness comes from ADVERT timestamp + radio config.
        -- Payload format: sf{sf}bw{bw_k}f{freq_khz}_{nonce:02x}
}

invariant MatrixCoverage {
    for experiment in Experiment:
        experiment.matrix.count >= 3

    @guidance
        -- Minimum 3 data points per experiment for meaningful
        -- comparison. Wider matrix = more data points preferred.
        -- 8+ points across SF/BW/freq matrix recommended.
}
