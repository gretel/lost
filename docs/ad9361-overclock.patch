AD9361 overclock patch for UHD (B200/B210 series)
==================================================

Source: https://github.com/MothMaux/uhd-oc (3 commits by ModderMax)
Local:  ../ettus-uhd-oc/

Raises AD9361 max sample rate from 61.44 MS/s to 122.88 MS/s.
Host-side only — single file modified, no FPGA or firmware changes.
Requires rebuilding libuhd from source.

Changes:
  - AD9361_MAX_CLOCK_RATE: 61.44e6 -> 122.88e6
  - VCO divider loop: i=1 -> i=0 (allows vcodiv=1)
  - Rate bracket 58-61.44 MHz extended to 58-70 MHz
  - New bracket 70-122.88 MHz: divfactor=4, FIR bypassed, rxfilt/txfilt=0xCC
  - RX timing register 0x006 tightened for >100 MS/s
  - FIR setup skipped when factor=0
  - set_clock_rate() guard raised to 122.88e6

Rate brackets (overclocked):
  <= 58 MS/s    divfactor=8-12  FIR 2x   Stock UHD
  58-70 MS/s    divfactor=8     FIR 2x   Extended bracket
  70-122.88     divfactor=4     FIR OFF  New OC bracket (no digital anti-alias)

Risks:
  - 61-100 MS/s: reportedly stable, ADC within spec (max 640 MHz)
  - >100 MS/s: degraded signal quality, timing register workaround
  - No FIR filtering above 70 MS/s (analog-only anti-aliasing)
  - USB3 bandwidth limits practical throughput (~56 MS/s MIMO, ~100 MS/s SISO)
  - Not validated by Analog Devices or Ettus

Apply against UHD 4.9.x:
  cd ettus-uhd && patch -p1 < ../gr4-lora/docs/ad9361-overclock.patch

--- a/host/lib/usrp/common/ad9361_driver/ad9361_device.cpp
+++ b/host/lib/usrp/common/ad9361_driver/ad9361_device.cpp
@@ -81,7 +81,7 @@
 
 const double ad9361_device_t::AD9361_MAX_GAIN         = 89.75;
 const double ad9361_device_t::AD9361_MIN_CLOCK_RATE   = 220e3;
-const double ad9361_device_t::AD9361_MAX_CLOCK_RATE   = 61.44e6;
+const double ad9361_device_t::AD9361_MAX_CLOCK_RATE   = 122.88e6;
 const double ad9361_device_t::AD9361_CAL_VALID_WINDOW = 100e6;
 // Max bandwdith is due to filter rolloff in analog filter stage
 const double ad9361_device_t::AD9361_MIN_BW = 200e3;
@@ -1217,7 +1217,7 @@
     int vcodiv;
 
     /* Iterate over VCO dividers until appropriate divider is found. */
-    int i = 1;
+    int i = 0;
     for (; i <= 6; i++) {
         vcodiv  = 1 << i;
         vcorate = rate * vcodiv;
@@ -1489,17 +1489,24 @@
         divfactor    = 12;
         _tfir_factor = 2;
         _rfir_factor = 2;
-    } else if ((rate > 58e6) && (rate <= 61.44e6)) {
+    } else if ((rate > 58e6) && (rate <= 70e6)) {
         // RX1 + RX2 enabled, 2, 1, 2, 2
         _regs.rxfilt = B8(11001110);
 
-
         // TX1 + TX2 enabled, 2, 1, 1, 2
         _regs.txfilt = B8(11010010);
 
         divfactor    = 8;
         _tfir_factor = 2;
         _rfir_factor = 2;
+    } else if ((rate > 70e6) && (rate <= 122.88e6)) {
+
+        _regs.rxfilt = B8(11001100);
+        _regs.txfilt = B8(11001100);
+
+        divfactor    = 4;
+        _tfir_factor = 0;
+        _rfir_factor = 0;
     } else {
         // should never get in here
         throw uhd::runtime_error("[ad9361_device_t] [_setup_rates] INVALID_CODE_PATH");
@@ -1543,6 +1550,12 @@
     _io_iface->poke8(0x004, _regs.inputsel);
     _io_iface->poke8(0x00A, _regs.bbpll);
 
+    if (rate > 100e6) {
+        _io_iface->poke8(0x006, 0x0A); // Decrease RX timings above 100e6
+    } else {
+        _io_iface->poke8(0x006, 0x0F); // Reset to default
+    }
+
     UHD_LOG_TRACE("AD936X", "[ad9361_device_t::_setup_rates] adcclk=" << adcclk);
     _baseband_bw = (adcclk / divfactor);
 
@@ -1566,8 +1579,8 @@
     const size_t num_tx_taps = get_num_taps(max_tx_taps);
     const size_t num_rx_taps = get_num_taps(max_rx_taps);
 
-    _setup_tx_fir(num_tx_taps, _tfir_factor);
-    _setup_rx_fir(num_rx_taps, _rfir_factor);
+    if (_tfir_factor != 0) {_setup_tx_fir(num_tx_taps, _tfir_factor);}
+    if (_rfir_factor != 0) {_setup_rx_fir(num_rx_taps, _rfir_factor);}
 
     return _baseband_bw;
 }
@@ -1857,7 +1870,7 @@
 {
     std::lock_guard<std::recursive_mutex> lock(_mutex);
 
-    if (req_rate > 61.44e6) {
+    if (req_rate > 122.88e6) {
         throw uhd::runtime_error(
             "[ad9361_device_t] Requested master clock rate outside range");
     }
