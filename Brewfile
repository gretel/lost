# gr4-lora build dependencies
# Install: brew bundle
# Verify:  brew bundle check

brew "llvm@19"      # C++23 toolchain (GR4 requires Clang >= 18)
brew "cmake"        # Build system (>= 3.27)
brew "ninja"        # Fast build backend
brew "ccache"       # Compiler cache
brew "soapysdr"     # Hardware abstraction layer for SDR devices
brew "uhd"          # Ettus USRP driver (loaded as SoapySDR plugin)
brew "cpplint"      # C++ style checker
